# Application
APP_ENV=development
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=chatapp
DB_SSLMODE=disable

# JWT — required, minimum 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS / WebSocket origin whitelist (comma-separated, no trailing slash)
# Only these origins are allowed to make cross-origin requests or open WebSocket connections.
# In development, localhost ports are allowed by default if this is not set.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

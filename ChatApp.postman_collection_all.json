        {
          "name": "Edit Message",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/messages/{{message_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"content\":\"Edited message content\"}"
            },
            "description": "Set message_id variable first. Only works within 3 min of sending and if unread."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// message_id must be set manually from a message sent via WebSocket.",
                  "// If message_id is empty, skip this test.",
                  "const mid = pm.collectionVariables.get('message_id');",
                  "if (!mid) {",
                  "  console.log('SKIP: message_id not set. Send a message via the browser client first, then copy its ID here.');",
                  "  return;",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/messages/{{message_id}}",
            "header": [
              {

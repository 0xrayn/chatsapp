{
  "info": {
    "name": "ChatApp API",
    "description": "Complete API collection for ChatApp. Covers auth, rooms, messages, DMs, and WebSocket protocol testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "token2",
      "value": "",
      "type": "string"
    },
    {
      "key": "room_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "message_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "dm_room_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user2_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Verify the server is running. Expected: 200 {\"status\":\"ok\",\"service\":\"chatapp\"}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Service ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User 1",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser1\",\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}"
            },
            "description": "Register first user. Expected: 201 with token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(j.token).to.be.a('string'));",
                  "pm.collectionVariables.set('token', j.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register User 2",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"testuser2\",\"email\":\"testuser2@mail.com\",\"password\":\"Test1234\"}"
            },
            "description": "Register second user for DM testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('token2', j.token);",
                  "pm.collectionVariables.set('user2_id', j.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Duplicate Email (expect error)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"other\",\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}"
            },
            "description": "Expected: 400/409 email already registered."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejected duplicate email', () => pm.expect(pm.response.code).to.be.oneOf([400,409]));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}"
            },
            "description": "Login and save token to collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(j.token).to.be.a('string'));",
                  "pm.collectionVariables.set('token', j.token);"

    {
      "name": "Rate Limiter",
      "item": [
        {
          "name": "Hammer Login (trigger 429)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"x@x.com\",\"password\":\"wrong\"}"
            },
            "description": "Run this request 15+ times in quick succession using Postman Runner. After ~10 requests you should receive 429 Too Many Requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [

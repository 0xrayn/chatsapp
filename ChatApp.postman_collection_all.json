            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "CORS",
      "item": [
        {
          "name": "Preflight Allowed Origin",
          "request": {
            "method": "OPTIONS",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Origin",
                "value": "http://localhost:3000"
              },
              {
                "key": "Access-Control-Request-Method",
                "value": "POST"
              }
            ],
            "description": "Expected: 204 + Access-Control-Allow-Origin header present."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));",
                  "pm.test('CORS header present', () => pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.eql('http://localhost:3000'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Preflight Blocked Origin",
          "request": {
            "method": "OPTIONS",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Origin",
                "value": "https://evil.com"
              },
              {
                "key": "Access-Control-Request-Method",
                "value": "POST"
              }
            ],
            "description": "Expected: 204 but NO Access-Control-Allow-Origin header."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('No CORS header for unknown origin', () => {",
                  "  const h = pm.response.headers.get('Access-Control-Allow-Origin');",
                  "  pm.expect(h === null || h === undefined || h === '').to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

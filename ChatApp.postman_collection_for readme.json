{
  "info": {
    "name": "ChatApp API",
    "description": "ChatApp API testing collection. Run requests top to bottom. Variables are saved automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "token2", "value": "", "type": "string" },
    { "key": "room_id", "value": "", "type": "string" },
    { "key": "dm_room_id", "value": "", "type": "string" },
    { "key": "user2_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Collection Runner",
      "item": [
        {
          "name": "Register User 1",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"testuser1\",\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('token', pm.response.json().token);"
          ]}}]
        },
        {
          "name": "Register User 2",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"testuser2\",\"email\":\"testuser2@mail.com\",\"password\":\"Test1234\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('token2', pm.response.json().token);",
            "pm.collectionVariables.set('user2_id', pm.response.json().user.id);"
          ]}}]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('token', pm.response.json().token);"
          ]}}]
        },
        {
          "name": "Login Wrong Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"testuser1@mail.com\",\"password\":\"wrongpass\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "Get Profile No Token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Use Revoked Token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('Revoked message', () => pm.expect(pm.response.json().error).to.include('revoked'));"
          ]}}]
        },
        {
          "name": "Login Again",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"testuser1@mail.com\",\"password\":\"Test1234\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('token', pm.response.json().token);"
          ]}}]
        },
        {
          "name": "CORS Allowed Origin",
          "request": {
            "method": "OPTIONS",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              { "key": "Origin", "value": "http://localhost:3000" },
              { "key": "Access-Control-Request-Method", "value": "POST" }
            ]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));",
            "pm.test('CORS header present', () => pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.eql('http://localhost:3000'));"
          ]}}]
        },
        {
          "name": "CORS Blocked Origin",
          "request": {
            "method": "OPTIONS",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              { "key": "Origin", "value": "https://evil.com" },
              { "key": "Access-Control-Request-Method", "value": "POST" }
            ]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('No CORS header for blocked origin', () => {",
            "  const h = pm.response.headers.get('Access-Control-Allow-Origin');",
            "  pm.expect(h === null || h === undefined || h === '').to.be.true;",
            "});"
          ]}}]
        },
        {
          "name": "Create Room",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/rooms",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"General\",\"description\":\"Main chat room\",\"type\":\"public\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('room_id', pm.response.json().id);"
          ]}}]
        },
        {
          "name": "Join Room User 2",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/rooms/{{room_id}}/join",
            "header": [{ "key": "Authorization", "value": "Bearer {{token2}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/rooms/{{room_id}}/messages?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "rooms", "{{room_id}}", "messages"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Get or Create DM Room",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/dm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"recipient_id\":\"{{user2_id}}\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('dm_room_id', j.id || j.room_id);"
          ]}}]
        },
        {
          "name": "Hammer Login (Rate Limiter)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"x@x.com\",\"password\":\"wrong\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('401 or 429', () => pm.expect(pm.response.code).to.be.oneOf([401, 429]));"
          ]}}]
        }
      ]
    }
  ]
}
